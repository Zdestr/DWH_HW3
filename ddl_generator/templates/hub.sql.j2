-- HUB: {{ hub_name }}
CREATE TABLE IF NOT EXISTS {{ hub_name }} (
    {{ hub_name }}_id        BIGINT          NOT NULL AUTO_INCREMENT COMMENT 'Surrogate key',
    {{ business_key_field }} {{ business_key_type }} NOT NULL        COMMENT 'Business key',
    load_dts                 DATETIME        NOT NULL                COMMENT 'Load timestamp',
    record_source            VARCHAR(255)    NOT NULL                COMMENT 'Source system',
    created_at               DATETIME        NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT 'Created timestamp'
)
UNIQUE KEY({{ hub_name }}_id, {{ business_key_field }})
DISTRIBUTED BY HASH({{ business_key_field }}) BUCKETS 4
PROPERTIES (
    "replication_num" = "1",
    "enable_unique_key_merge_on_write" = "true"
);
